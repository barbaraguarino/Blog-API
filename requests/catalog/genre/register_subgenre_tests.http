  "password": "SenhaForte@123"
}

### CRIAR SUBGÊNERO COM SUCESSO (201 CREATED)
POST http://localhost:8080/api/v1/genres/03dd5aba-7d3f-441e-9500-8a21a08f937c/subgenres
Content-Type: application/json

{
  "translations": [
    {
      "languageCode": "pt-BR",
      "name": "Alta Fantasia"
    },
    {
      "languageCode": "en-US",
      "name": "High Fantasy"
    }
  ]
}

